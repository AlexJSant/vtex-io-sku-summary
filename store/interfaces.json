{
  "sku-summary-list": {
    "component": "SkuSummaryList",
    "content": {
      "properties": {
        "productId": {
          "title": "admin/editor.skuSummaryList.productId.title",
          "description": "admin/editor.skuSummaryList.productId.description",
          "type": "string"
        },
        "skus": {
          "$ref": "app:sunhouse.sku-summary#/definitions/ManualSkus"
        },
        "listName": {
          "title": "admin/editor.skuSummaryList.listName.title",
          "type": "string",
          "default": "SKU list"
        },
        "itemsFilter": {
          "title": "admin/editor.skuSummaryList.itemsFilter.title",
          "description": "admin/editor.skuSummaryList.itemsFilter.description",
          "type": "string",
          "enum": ["ALL", "FIRST_AVAILABLE", "ALL_AVAILABLE"],
          "default": "ALL_AVAILABLE"
        },
        "maxItems": {
          "title": "admin/editor.skuSummaryList.maxItems.title",
          "description": "admin/editor.skuSummaryList.maxItems.description",
          "type": "number",
          "minimum": 1
        }
      }
    },
    "composition": "children",
    "allowed": ["sku-summary"],
    "preview": {
      "type": "grid",
      "height": 550
    }
  },
  "sku-summary": {
    "component": "SkuSummaryCustom",
    "composition": "children"
  },
  "sku-summary.shelf": {
    "component": "SkuSummaryCustom",
    "composition": "children"
  },
  "sku-summary-column": {
    "component": "Column",
    "composition": "children"
  },
  "sku-summary-space": {
    "component": "Spacer"
  },
  "sku-summary-attachment-list": {
    "component": "SkuSummaryAttachmentList"
  },
  "sku-summary-buy-button": {
    "component": "SkuSummaryBuyButton",
    "content": {
      "properties": {
        "buyButtonText": {
          "$ref": "app:sunhouse.sku-summary#/definitions/ProductSummary/properties/buyButtonText"
        }
      }
    }
  },
  "sku-summary-image": {
    "component": "SkuSummaryImage",
    "content": {
      "properties": {
        "badgeText": {
          "$ref": "app:sunhouse.sku-summary#/definitions/ProductSummary/properties/badgeText"
        }
      }
    }
  },
  "sku-summary-name": {
    "component": "SkuSummaryName"
  },
  "sku-summary-sku-name": {
    "component": "SkuSummarySKUName"
  },
  "sku-summary-price": {
    "component": "SkuSummaryPrice",
    "content": {
      "properties": {
        "labelSellingPrice": {
          "$ref": "app:sunhouse.sku-summary#/definitions/ProductSummary/properties/labelSellingPrice"
        },
        "labelListPrice": {
          "$ref": "app:sunhouse.sku-summary#/definitions/ProductSummary/properties/labelListPrice"
        }
      }
    }
  }
}
